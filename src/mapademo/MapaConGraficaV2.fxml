<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@estilos.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mapademo.MapaConGraficaController">

    <!-- ===== BARRA SUPERIOR (igual que Dashboard) ===== -->
    <top>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="top-bar">
                    <children>
                        <Label fx:id="avatarLabel" text="👤" />
                        <Label fx:id="usuarioLabel" text="Hola, jpgarcia" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Hyperlink fx:id="gestionMapasLink" text="Gestión de Mapas" underline="true">
                            <font><Font size="14.0" /></font>
                        </Hyperlink>
                        <Hyperlink fx:id="miPerfilLink" text="Editar Perfil" underline="true">
                            <font><Font size="14.0" /></font>
                        </Hyperlink>

                        <Button fx:id="cerrarSesionButton" mnemonicParsing="false"
                                prefHeight="35.0" text="Cerrar sesión" />
                        <Button fx:id="ajustesButton" mnemonicParsing="false"
                                prefHeight="35.0" prefWidth="45.0" text="⚙">
                            <font><Font size="16.0" /></font>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="8.0" left="10.0" right="10.0" top="8.0" />
                    </padding>
                </HBox>

                <Separator />

            </children>
        </VBox>
    </top>

    <!-- ===== PANEL IZQUIERDO (sidebar estilo Dashboard) ===== -->
    <left>
        <HBox BorderPane.alignment="TOP_LEFT">
            <children>
                <VBox prefWidth="180.0" spacing="0.0" styleClass="sidebar" HBox.hgrow="ALWAYS">
                    <children>
                        <!-- Botón principal -->
                        <Button fx:id="importarGPXButton" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" prefHeight="60.0"
                                styleClass="button-start" text="Añadir actividad"
                                textAlignment="CENTER" wrapText="true">
                            <VBox.margin>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </VBox.margin>
                        </Button>

                        <Separator />

                        <Label fx:id="resumenGeneralLabel" text="🏠  Resumen General">
                            <font><Font name="System Bold" size="16.0" /></font>
                            <padding>
                                <Insets bottom="8.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </Label>

                        <Separator />

                        <Label text="Lista de Actividades">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding>
                                <Insets bottom="6.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </Label>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Hyperlink fx:id="actividadLink1" text="Entrenamiento Gandía">
                                    <padding>
                                        <Insets bottom="4.0" left="10.0" right="0.0" top="4.0" />
                                    </padding>
                                </Hyperlink>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="eliminarActividad1Button"
                                        styleClass="button-danger" text="X">
                                    <font><Font name="System Bold" size="10.0" /></font>
                                    <HBox.margin><Insets right="5.0" /></HBox.margin>
                                </Button>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Hyperlink fx:id="actividadLink2" text="Subida Mondúber">
                                    <padding>
                                        <Insets bottom="4.0" left="10.0" right="0.0" top="4.0" />
                                    </padding>
                                </Hyperlink>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="eliminarActividad2Button"
                                        styleClass="button-danger" text="X">
                                    <font><Font name="System Bold" size="10.0" /></font>
                                    <HBox.margin><Insets right="5.0" /></HBox.margin>
                                </Button>
                            </children>
                        </HBox>

                        <ListView fx:id="map_listview" onMouseClicked="#listClicked"
                                  VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
                <Separator orientation="VERTICAL" />
            </children>
        </HBox>
    </left>

    <!-- ===== CONTENIDO CENTRAL (Mapa + Panel Stats) ===== -->
    <center>
        <SplitPane fx:id="splitPane" dividerPositions="0.65">
            <items>

                <!-- Mapa con Zoom superpuesto -->
                <StackPane SplitPane.resizableWithParent="true">
                    <children>
                        <ScrollPane fx:id="map_scrollpane" hbarPolicy="ALWAYS"
                                    onMouseMoved="#showPosition" pannable="true"
                                    vbarPolicy="ALWAYS">
                            <content>
                                <Pane>
                                    <children>
                                        <ImageView pickOnBounds="true">
                                            <image>
                                                <Image url="@../resources/upv.jpg" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </Pane>
                            </content>
                        </ScrollPane>

                        <!-- Controles de Zoom superpuestos -->
                        <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                              spacing="10.0" styleClass="map-overlay-zoom"
                              StackPane.alignment="BOTTOM_CENTER">
                            <children>
                                <Label text="Zoom" />
                                <Button mnemonicParsing="false" onAction="#zoomOut" text="-"
                                        styleClass="button-secondary" />
                                <Slider fx:id="zoom_slider" prefWidth="150.0" />
                                <Button mnemonicParsing="false" onAction="#zoomIn" text="+"
                                        styleClass="button-secondary" />
                            </children>
                            <StackPane.margin>
                                <Insets bottom="20.0" />
                            </StackPane.margin>
                        </HBox>
                    </children>
                </StackPane>

                <!-- Panel derecho: Slider + Stats cards + Gráfica -->
                <VBox spacing="12.0" styleClass="stats-panel"
                      SplitPane.resizableWithParent="false">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>

                        <!-- Título -->
                        <Label styleClass="label-title" text="Detalles" />

                        <!-- Tarjeta: Slider de progreso -->
                        <VBox styleClass="card" spacing="6.0">
                            <children>
                                <Label styleClass="label-secondary" text="Progreso en ruta" />
                                <Slider fx:id="progresoSlider" min="0" max="100" value="0"
                                        showTickMarks="true" showTickLabels="true"
                                        majorTickUnit="25" blockIncrement="5" />
                                <Label fx:id="posicionSliderLabel"
                                       styleClass="label-secondary" text="0,0 km" />
                            </children>
                        </VBox>

                        <!-- Tarjeta: Ritmo medio -->
                        <VBox alignment="TOP_LEFT" spacing="8.0" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="label-secondary" text="Ritmo medio:" />
                                        <Label text="🏃">
                                            <font><Font size="20.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                                <Label fx:id="ritmoLabel" styleClass="label-metric"
                                       text="4:50 min/km" />
                            </children>
                        </VBox>

                        <!-- Tarjeta: Velocidad media -->
                        <VBox alignment="TOP_LEFT" spacing="8.0" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="label-secondary" text="Velocidad media:" />
                                        <Label text="⚡">
                                            <font><Font size="20.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                                <Label fx:id="velocidadLabel" styleClass="label-metric"
                                       text="12,4 km/h" />
                            </children>
                        </VBox>

                        <!-- Tarjeta: Altitud -->
                        <VBox alignment="TOP_LEFT" spacing="8.0" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="label-secondary" text="Altitud máxima:" />
                                        <Label text="⬆">
                                            <font><Font size="20.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                                <Label fx:id="altitudLabel" styleClass="label-metric"
                                       text="450 m" />
                                <Label styleClass="label-secondary" text="Desnivel: +10 m" />
                            </children>
                        </VBox>

                        <!-- Gráfica de altitud -->
                        <LineChart fx:id="altitudChart" animated="false"
                                   title="Perfil de altitud" VBox.vgrow="ALWAYS">
                            <xAxis>
                                <NumberAxis fx:id="ejeDistancia" autoRanging="false"
                                            label="Distancia (km)" lowerBound="0"
                                            tickUnit="0.5" upperBound="13" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="ejeAltitud" autoRanging="false"
                                            label="Altitud (m)" lowerBound="0"
                                            tickUnit="250" upperBound="1500" />
                            </yAxis>
                        </LineChart>

                    </children>
                </VBox>

            </items>
        </SplitPane>
    </center>

    <!-- ===== BARRA DE ESTADO INFERIOR ===== -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="mousePosition" minHeight="-Infinity" minWidth="-Infinity"
                       text="SceneX:     SceneY:     " wrapText="true"
                       HBox.hgrow="ALWAYS" />
            </children>
            <BorderPane.margin>
                <Insets bottom="6.0" left="6.0" right="6.0" top="6.0" />
            </BorderPane.margin>
        </HBox>
    </bottom>

</BorderPane>
