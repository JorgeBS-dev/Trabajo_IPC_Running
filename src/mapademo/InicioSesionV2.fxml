<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:id="rootPane" fx:controller="mapademo.LoginController" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="800.0" prefWidth="1200.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <!-- Panel del Formulario (Lado Izquierdo) -->
      <VBox alignment="CENTER" prefWidth="500.0" minWidth="450.0" styleClass="form-pane">
         <children>
            <VBox alignment="CENTER_LEFT" maxWidth="400.0" spacing="30.0">
               <children>
                  <Label text="Inicio de Sesión">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
                  
                  <VBox spacing="20.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Email o Nickname:" />
                              <TextField fx:id="identificadorField" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="usuario o usuario@dominio.com" />
                              <VBox fx:id="loginHelpBox" managed="false" spacing="2.0" visible="false" style="-fx-background-color: #f8f9fa; -fx-padding: 5; -fx-background-radius: 5;">
                                 <children>
                                    <Label text="• Usa tu nickname (6-15 caracteres)" style="-fx-font-size: 11px;" />
                                    <Label text="• O tu email (formato válido)" style="-fx-font-size: 11px;" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                        
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Contraseña:" />
                              <HBox alignment="CENTER_LEFT" spacing="5.0">
                                 <children>
                                    <PasswordField fx:id="passwordField" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Ingresa tu contraseña" HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="passwordTextField" managed="false" visible="false" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Ingresa tu contraseña" HBox.hgrow="ALWAYS" />
                                    <ToggleButton fx:id="togglePasswordButton" mnemonicParsing="false" prefHeight="35.0" text="👁" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0">
                     <children>
                        <Label fx:id="mensajeLabel" textFill="RED" wrapText="true" />
                        <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="250.0" text="Iniciar sesión">
                           <font>
                              <Font size="16.0" />
                           </font>
                        </Button>
                        <Hyperlink fx:id="registroHyperlink" onAction="#handleGoToRegister" text="¿No tienes cuenta? Regístrate" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>

      <!-- Panel Decorativo (Lado Derecho) -->
      <VBox alignment="CENTER" spacing="20.0" styleClass="hero-pane" HBox.hgrow="ALWAYS">
         <children>
            <Label text="🏃" style="-fx-font-size: 120px;" />
            <Label styleClass="hero-text-title" text="¡Hola de nuevo!" textAlignment="CENTER" wrapText="true" />
            <Label styleClass="hero-text-subtitle" text="Tu próxima aventura comienza aquí. Accede para revisar tus rutas y estadísticas." textAlignment="CENTER" wrapText="true">
               <VBox.margin>
                  <Insets left="40.0" right="40.0" />
               </VBox.margin>
            </Label>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</HBox>
