<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" prefHeight="556.0" prefWidth="853.0" spacing="30.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="Inicio de Sesión">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      
      <VBox maxWidth="400.0" spacing="20.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Email o Nickname:" />
                  <TextField fx:id="identificadorField" prefHeight="35.0" promptText="usuario o usuario@dominio.com" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Contraseña:" />
                  <HBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
                        <PasswordField fx:id="passwordField" maxWidth="320.0" prefHeight="35.0" promptText="Ingresa tu contraseña" HBox.hgrow="ALWAYS" />
                        <ToggleButton fx:id="togglePasswordButton" mnemonicParsing="false" prefHeight="35.0" text="👁" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
      
      <VBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label fx:id="mensajeLabel" textFill="RED" wrapText="true" />
            <Button mnemonicParsing="false" prefHeight="45.0" prefWidth="250.0" text="Iniciar sesión">
               <font>
                  <Font size="16.0" />
               </font>
            </Button>
            <Hyperlink fx:id="registroHyperlink" text="¿No tienes cuenta? Regístrate" />
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>
</VBox>
