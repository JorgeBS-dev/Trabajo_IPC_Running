<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="mapademo.GestionMapasController" alignment="TOP_CENTER" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <fx:include source="TopBar.fxml" />
      <VBox maxWidth="1.7976931348623157E308" spacing="25.0" VBox.vgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleVolver" text="⬅ Volver" styleClass="button-secondary" />
                  <Label text="Gestión de Mapas">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
               </children>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Lista de Mapas -->
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Mapas Disponibles:" styleClass="label-secondary" />
                        <ListView fx:id="mapasListView" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>

                  <!-- Panel de Importación -->
                  <VBox spacing="15.0" prefWidth="300.0" styleClass="card">
                     <children>
                        <Label text="Importar Nuevo Mapa" styleClass="label-title" style="-fx-font-size: 18px;" />
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Nombre del mapa:" />
                              <TextField fx:id="nombreMapaField" promptText="Ej: Sierra de Espadán" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Coordenadas (Opcional para visualización):" />
                              <TextField fx:id="coordsField" promptText="minLat, maxLat, minLon, maxLon" disable="true" />
                              <Label text="* Se usarán valores por defecto si no se especifican" style="-fx-font-size: 10px;" textFill="#666666" />
                           </children>
                        </VBox>
                        <Button fx:id="seleccionarJPGButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Seleccionar JPG" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="importarButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Añadir a la Biblioteca" styleClass="button-start" />
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</VBox>
